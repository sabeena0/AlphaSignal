# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Choose one: "groq" (recommended — free & fast), "openai", or "anthropic"
LLM_PROVIDER=groq

# ─── Groq (Recommended — Free, No Credit Card) ────────────────────────────────
# Sign up at: https://console.groq.com → API Keys → Create API Key
GROQ_API_KEY=gsk_...

# ─── OpenAI (Alternative) ─────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ─── Anthropic Claude (Alternative) ───────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Tavily Search (Required for Live Data) ───────────────────────────────────
# Sign up at: https://tavily.com → Free tier: 1000 searches/month
TAVILY_API_KEY=tvly-...
